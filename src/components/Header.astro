---
import { personalInfo } from "../data/portfolio";
---

<header
  class="fixed top-0 w-full bg-white/95 backdrop-blur-sm z-50 border-b border-slate-200"
>
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-3">
        <span
          class="w-9 h-9 bg-slate-900 text-white text-sm font-bold flex items-center justify-center rounded"
        >
          {personalInfo.name[0]}{personalInfo.lastName[0]}
        </span>
        <span
          class="text-slate-900 font-semibold hidden sm:block text-sm tracking-wide"
        >
          {personalInfo.name}
          {personalInfo.lastName}
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="#about"
          class="nav-link text-slate-500 hover:text-cyan-600 text-sm font-medium tracking-wide transition-colors duration-200"
          >About</a
        >
        <a
          href="#experience"
          class="nav-link text-slate-500 hover:text-cyan-600 text-sm font-medium tracking-wide transition-colors duration-200"
          >Experience</a
        >
        <a
          href="#projects"
          class="nav-link text-slate-500 hover:text-cyan-600 text-sm font-medium tracking-wide transition-colors duration-200"
          >Projects</a
        >
        <a
          href="#skills"
          class="nav-link text-slate-500 hover:text-cyan-600 text-sm font-medium tracking-wide transition-colors duration-200"
          >Skills</a
        >
        <a
          href="#contact"
          class="px-5 py-2 bg-slate-900 hover:bg-cyan-600 text-white text-sm font-medium rounded transition-colors duration-200"
          >Contact</a
        >
      </div>

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors"
        aria-label="Toggle menu"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden mt-4 pb-2 border-t border-slate-100 pt-4"
    >
      <div class="flex flex-col gap-4">
        <a
          href="#about"
          class="nav-link-mobile text-slate-600 hover:text-cyan-600 text-sm font-medium transition-colors"
          >About</a
        >
        <a
          href="#experience"
          class="nav-link-mobile text-slate-600 hover:text-cyan-600 text-sm font-medium transition-colors"
          >Experience</a
        >
        <a
          href="#projects"
          class="nav-link-mobile text-slate-600 hover:text-cyan-600 text-sm font-medium transition-colors"
          >Projects</a
        >
        <a
          href="#skills"
          class="nav-link-mobile text-slate-600 hover:text-cyan-600 text-sm font-medium transition-colors"
          >Skills</a
        >
        <a
          href="#contact"
          class="nav-link-mobile text-slate-600 hover:text-cyan-600 text-sm font-medium transition-colors"
          >Contact</a
        >
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  const mobileLinks = document.querySelectorAll(".nav-link-mobile");
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });
</script>
