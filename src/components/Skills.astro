---
import { skills } from "../data/portfolio";

const accentConfig = [
  {
    border: "border-cyan-500",
    label: "text-cyan-600",
    dot: "bg-cyan-500",
    bg: "bg-cyan-50",
  },
  {
    border: "border-slate-600",
    label: "text-slate-700",
    dot: "bg-slate-600",
    bg: "bg-slate-100",
  },
  {
    border: "border-teal-500",
    label: "text-teal-600",
    dot: "bg-teal-500",
    bg: "bg-teal-50",
  },
  {
    border: "border-sky-500",
    label: "text-sky-600",
    dot: "bg-sky-500",
    bg: "bg-sky-50",
  },
  {
    border: "border-rose-400",
    label: "text-rose-600",
    dot: "bg-rose-400",
    bg: "bg-rose-50",
  },
  {
    border: "border-violet-400",
    label: "text-violet-600",
    dot: "bg-violet-400",
    bg: "bg-violet-50",
  },
];
---

<section id="skills" class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-px bg-cyan-600"></div>
          <span
            class="text-cyan-600 text-sm font-semibold uppercase tracking-widest"
            >Skills</span
          >
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900">
          Technical Competencies
        </h2>
        <p class="text-slate-500 mt-4 max-w-2xl text-sm leading-relaxed">
          A comprehensive overview of the tools, systems, and practices I use
          daily to manage business operations, automate processes, and build
          digital solutions.
        </p>
      </div>

      <!-- Skills Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {
          skills.map((skillCategory, index) => {
            const accent = accentConfig[index % accentConfig.length];
            return (
              <div
                class={`border-t-2 ${accent.border} bg-white border border-slate-200 rounded-xl p-6 hover:shadow-md transition-shadow duration-300`}
              >
                <h3
                  class={`text-xs font-bold uppercase tracking-widest mb-4 ${accent.label}`}
                >
                  {skillCategory.category}
                </h3>
                <div class="flex flex-wrap gap-2">
                  {skillCategory.skills.map((skill) => (
                    <span
                      class={`inline-flex items-center gap-1.5 px-2.5 py-1 ${accent.bg} border border-slate-200 text-slate-700 text-xs rounded font-medium`}
                    >
                      <span
                        class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${accent.dot}`}
                      />
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Bottom Banner -->
      <div
        class="bg-slate-900 rounded-xl p-10 flex flex-col md:flex-row items-center justify-between gap-8"
      >
        <div>
          <h3 class="text-xl font-bold text-white mb-2">
            Continuous Learning & Applied AI
          </h3>
          <p class="text-slate-400 max-w-xl text-sm leading-relaxed">
            I actively leverage GitHub Copilot and AI tools to accelerate
            development and solve complex problems. I stay current with ERP
            updates, automation best practices, and web standards to
            continuously improve operational efficiency and deliver real
            business value.
          </p>
        </div>
        <a
          href="#contact"
          class="px-6 py-3 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold rounded transition-colors whitespace-nowrap flex-shrink-0 text-sm"
        >
          Work Together
        </a>
      </div>
    </div>
  </div>
</section>
