---
import { experience } from '../data/portfolio';
---

<section id="experience" class="py-24 bg-slate-50">
  <div class="container mx-auto px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Section Header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-px bg-cyan-600"></div>
          <span class="text-cyan-600 text-sm font-semibold uppercase tracking-widest">Experience</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900">Professional Journey</h2>
      </div>

      <!-- Experience Cards -->
      <div class="space-y-6">
        {experience.map((exp) => (
          <div class="bg-white border border-slate-200 rounded-xl p-8 hover:border-cyan-300 hover:shadow-md transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h3 class="text-xl font-bold text-slate-900">{exp.position}</h3>
                <h4 class="text-cyan-600 font-medium mt-1">{exp.company}</h4>
              </div>
              <span class="inline-flex items-center px-4 py-1.5 bg-slate-100 text-slate-600 text-sm font-medium rounded-full whitespace-nowrap self-start">
                {exp.period}
              </span>
            </div>

            <p class="text-slate-600 leading-relaxed mb-6">{exp.description}</p>

            <div class="flex flex-wrap gap-2">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 bg-slate-50 border border-slate-200 text-slate-600 text-xs font-medium rounded">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-white">
          My <span class="text-blue-600">Experience</span>
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300">
          My professional journey in software development
        </p>
      </div>
      
      <!-- Timeline -->
      <div class="relative">
        <!-- Timeline Line -->
        <div class="absolute left-1/2 transform -translate-x-px h-full w-0.5 bg-blue-200 dark:bg-blue-800"></div>
        
        <!-- Experience Items -->
        <div class="space-y-12">
          {experience.map((exp, index) => (
            <div class="relative flex items-center">
              <!-- Timeline Dot -->
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-600 rounded-full border-4 border-white dark:border-gray-800 z-10"></div>
              
              <!-- Content -->
              <div class={`w-full ${index % 2 === 0 ? 'lg:pr-1/2' : 'lg:pl-1/2 lg:text-right'}`}>
                <div class={`bg-white dark:bg-gray-900 p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 ${index % 2 === 0 ? 'lg:mr-8' : 'lg:ml-8'}`}>
                  <!-- Period -->
                  <div class="inline-block bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 px-3 py-1 rounded-full text-sm font-medium mb-4">
                    {exp.period}
                  </div>
                  
                  <!-- Position & Company -->
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                    {exp.position}
                  </h3>
                  <h4 class="text-lg text-blue-600 dark:text-blue-400 font-medium mb-4">
                    {exp.company}
                  </h4>
                  
                  <!-- Description -->
                  <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
                    {exp.description}
                  </p>
                  
                  <!-- Technologies -->
                  <div class="flex flex-wrap gap-2">
                    {exp.technologies.map((tech) => (
                      <span class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1 rounded-full text-sm">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
