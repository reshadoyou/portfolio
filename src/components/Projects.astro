---
import { projects } from '../data/portfolio';

const projectFeatures = [
  { icon: "🔍", label: "Technical SEO", detail: "Sitemap.xml, Robots.txt, Schema.org, Structured Data" },
  { icon: "📱", label: "Social Meta Tags", detail: "Open Graph, Twitter Cards, rich previews" },
  { icon: "♿", label: "Accessibility", detail: "ARIA roles, semantic HTML, WCAG guidelines" },
  { icon: "🔒", label: "Security", detail: "Honeypot anti-spam, form validation, security headers" },
  { icon: "⚡", label: "Performance", detail: "Optimized assets, fast load times, responsive layout" },
  { icon: "🌐", label: "Hosting & Domain", detail: "Domain config, cPanel, continuous deployment" },
];
---

<section id="projects" class="py-24 bg-slate-50">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">

      <!-- Section Header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-px bg-cyan-600"></div>
          <span class="text-cyan-600 text-sm font-semibold uppercase tracking-widest">Projects</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900">Featured Work</h2>
      </div>

      <!-- Main Project Card -->
      {projects.filter(project => project.featured).map((project) => (
        <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">

          <!-- Top: Image + Title + CTA -->
          <div class="grid lg:grid-cols-5">
            <!-- Image Panel -->
            <div class="lg:col-span-2 bg-slate-800 flex items-center justify-center p-10 min-h-[240px]">
              {project.image ? (
                <img
                  src={`/portfolio/${project.image}`}
                  alt={project.title}
                  class="max-h-44 w-auto object-contain rounded-lg shadow-xl"
                />
              ) : (
                <span class="text-white text-3xl font-bold">{project.title.split(' ').map((w: string) => w[0]).join('')}</span>
              )}
            </div>

            <!-- Content Panel -->
            <div class="lg:col-span-3 p-8 flex flex-col justify-between">
              <div>
                <!-- Badge -->
                <span class="inline-block px-3 py-1 bg-cyan-50 border border-cyan-200 text-cyan-700 text-xs font-semibold rounded-full mb-4 uppercase tracking-wide">
                  Corporate Website · AI-Assisted Development
                </span>

                <h4 class="text-2xl font-bold text-slate-900 mb-3">{project.title}</h4>
                <p class="text-slate-600 leading-relaxed mb-6 text-sm">{project.description}</p>

                <!-- Technologies -->
                <div class="flex flex-wrap gap-2">
                  {project.technologies.map((tech) => (
                    <span class="px-2.5 py-1 bg-slate-100 border border-slate-200 text-slate-700 text-xs font-medium rounded">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              <!-- CTA -->
              <div class="flex items-center gap-4 mt-8 pt-6 border-t border-slate-100">
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-7 py-3 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold rounded transition-colors duration-200"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                    Visit meredith.cl
                  </a>
                )}
                <span class="text-slate-400 text-xs">↑ Live production site</span>
              </div>
            </div>
          </div>

          <!-- Bottom: Feature Highlights -->
          <div class="border-t border-slate-100 bg-slate-50 px-8 py-6">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">What was implemented</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {projectFeatures.map((feat) => (
                <div class="flex items-start gap-3">
                  <span class="text-lg flex-shrink-0">{feat.icon}</span>
                  <div>
                    <div class="text-slate-800 text-xs font-semibold">{feat.label}</div>
                    <div class="text-slate-500 text-xs mt-0.5">{feat.detail}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      ))}

    </div>
  </div>
</section>
