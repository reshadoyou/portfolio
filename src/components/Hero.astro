---
import { personalInfo } from "../data/portfolio";
---

<section id="hero" class="min-h-screen flex items-center bg-slate-900 pt-16">
  <div class="container mx-auto px-6 py-24">
    <div class="max-w-5xl mx-auto">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-px bg-cyan-500"></div>
        <span
          class="text-cyan-500 text-sm font-semibold uppercase tracking-widest"
          >{personalInfo.title}</span
        >
      </div>

      <!-- Profile + Name Row -->
      <div class="flex flex-col md:flex-row md:items-center gap-8 mb-8">
        <div
          class="w-24 h-24 rounded-full overflow-hidden border-2 border-slate-700 flex-shrink-0"
        >
          <img
            src="/portfolio/profile.jpg"
            alt="Eileen Meredith"
            class="w-full h-full object-cover"
          />
        </div>
        <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">
          {personalInfo.name}<br />
          <span class="text-cyan-500">{personalInfo.lastName}</span>
        </h1>
      </div>

      <!-- Bio -->
      <p
        class="text-lg md:text-xl text-slate-400 max-w-2xl mb-12 leading-relaxed"
      >
        {personalInfo.bio}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 mb-20">
        <a
          href="#contact"
          class="px-8 py-3 bg-cyan-600 hover:bg-cyan-500 text-white font-semibold rounded transition-colors duration-200"
        >
          Get in Touch
        </a>
        <a
          href="#experience"
          class="px-8 py-3 border border-slate-600 hover:border-cyan-500 text-slate-300 hover:text-cyan-400 font-semibold rounded transition-colors duration-200"
        >
          View Experience
        </a>
        <a
          href={personalInfo.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3 border border-slate-600 hover:border-cyan-500 text-slate-300 hover:text-cyan-400 font-semibold rounded transition-colors duration-200"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>

      <!-- Key Competencies Row -->
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-slate-800"
      >
        <div>
          <div
            class="text-cyan-400 font-semibold mb-1 text-xs uppercase tracking-widest"
          >
            ERP Systems
          </div>
          <div class="text-slate-500 text-sm">Softland · Operations</div>
        </div>
        <div>
          <div
            class="text-cyan-400 font-semibold mb-1 text-xs uppercase tracking-widest"
          >
            Automation
          </div>
          <div class="text-slate-500 text-sm">VBA · Workflows</div>
        </div>
        <div>
          <div
            class="text-cyan-400 font-semibold mb-1 text-xs uppercase tracking-widest"
          >
            Cost Control
          </div>
          <div class="text-slate-500 text-sm">Inventory · Valuations</div>
        </div>
        <div>
          <div
            class="text-cyan-400 font-semibold mb-1 text-xs uppercase tracking-widest"
          >
            Web Development
          </div>
          <div class="text-slate-500 text-sm">AI-Assisted · Corporate</div>
        </div>
      </div>
    </div>
  </div>
</section>
<div class="container mx-auto px-4 py-20">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Profile Image -->
    <div class="mb-8">
      <div
        class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-r from-blue-500 to-purple-600 p-1"
      >
        <img
          src="/portfolio/profile.jpg"
          alt="Profile Image"
          class="w-full h-full object-cover rounded-full"
        />
      </div>
    </div>

    <!-- Name and Title -->
    <h1
      class="text-5xl md:text-7xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"
    >
      {personalInfo.name}
      {personalInfo.lastName}
    </h1>

    <h2
      class="text-2xl md:text-3xl text-gray-600 dark:text-gray-300 mb-6 font-light"
    >
      {personalInfo.title}
    </h2>

    <!-- Bio -->
    <p
      class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed"
    >
      {personalInfo.bio}
    </p>

    <!-- Social Links con flecha al lado izquierdo de GitHub -->
    <div class="flex justify-center space-x-6 items-center">
      <!-- Flecha al lado izquierdo de GitHub, apuntando hacia la derecha -->
      <span>
        <svg
          class="w-6 h-6 text-gray-400 animate-bounce"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 5l7 7-7 7"></path>
        </svg>
      </span>
      <a
        href={personalInfo.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200"
        aria-label="GitHub"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
      <a
        href={personalInfo.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200"
        aria-label="LinkedIn"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</div>
