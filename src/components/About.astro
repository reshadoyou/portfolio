---
import { personalInfo } from "../data/portfolio";
---

<section id="about" class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-px bg-cyan-600"></div>
          <span
            class="text-cyan-600 text-sm font-semibold uppercase tracking-widest"
            >About</span
          >
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900">
          Technology Applied to<br /><span class="text-cyan-600"
            >Real Business Operations</span
          >
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <!-- Left: Bio text -->
        <div class="space-y-6">
          <p class="text-lg text-slate-600 leading-relaxed">
            I am an IT Engineer with hands-on experience in the internal
            operations of a company â€” from purchasing and stock valuation to
            invoicing, credit notes, and cost management. My work focuses on
            applying technology to streamline real business processes, not just
            building software for its own sake.
          </p>
          <p class="text-lg text-slate-600 leading-relaxed">
            At Meredith Fueltec Ltda., I manage the company's administrative
            workflow using <strong class="text-slate-800">Softland ERP</strong>,
            oversee inventory control and cost analysis, and develop <strong
              class="text-slate-800">Excel VBA automations</strong
            > that eliminate repetitive manual tasks and improve data accuracy across
            the organization.
          </p>
          <p class="text-lg text-slate-600 leading-relaxed">
            I also led the development of the company's corporate website, using
            AI as a development tool combined with my own technical knowledge in
            web programming. This project reflects my ability to deliver
            complete digital solutions by integrating modern tools with
            analytical thinking and deep business understanding.
          </p>

          <!-- What I Do -->
          <div class="pt-4 space-y-5 border-t border-slate-100">
            <div class="flex items-start gap-4">
              <div
                class="w-1 min-h-[2.5rem] bg-cyan-600 rounded flex-shrink-0 mt-0.5"
              >
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">
                  Business Operations Management
                </h4>
                <p class="text-slate-500 text-sm mt-0.5">
                  Inventory management, stock valuation, cost control &
                  analysis, purchasing, purchase order tracking, quotations,
                  invoicing, credit notes, exchange rate analysis
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-1 min-h-[2.5rem] bg-cyan-600 rounded flex-shrink-0 mt-0.5"
              >
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">
                  ERP Administration & Process Automation
                </h4>
                <p class="text-slate-500 text-sm mt-0.5">
                  Softland ERP operation, commercial module management, VBA
                  macro development, report automation, reconciliation scripts,
                  digital workflow design
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-1 min-h-[2.5rem] bg-cyan-600 rounded flex-shrink-0 mt-0.5"
              >
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">
                  Web Development & Digital Transformation
                </h4>
                <p class="text-slate-500 text-sm mt-0.5">
                  Full corporate website development, technical SEO,
                  accessibility (ARIA/WCAG), security standards, hosting, domain
                  management, AI-assisted programming
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-1 min-h-[2.5rem] bg-cyan-600 rounded flex-shrink-0 mt-0.5"
              >
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">
                  Data Analysis & Decision Support
                </h4>
                <p class="text-slate-500 text-sm mt-0.5">
                  Analytical reporting, data processing, operational insights to
                  support management decision-making
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Highlights -->
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-slate-900 p-6 rounded-xl text-center">
              <div class="text-3xl font-bold text-cyan-400 mb-2">2+</div>
              <div class="text-slate-400 text-sm">
                Years in Business Operations
              </div>
            </div>
            <div
              class="bg-slate-50 border border-slate-200 p-6 rounded-xl text-center"
            >
              <div class="text-3xl font-bold text-slate-900 mb-2">ERP</div>
              <div class="text-slate-500 text-sm">Softland Administration</div>
            </div>
            <div
              class="bg-slate-50 border border-slate-200 p-6 rounded-xl text-center"
            >
              <div class="text-3xl font-bold text-slate-900 mb-2">VBA</div>
              <div class="text-slate-500 text-sm">Process Automation</div>
            </div>
            <div class="bg-cyan-600 p-6 rounded-xl text-center">
              <div class="text-3xl font-bold text-white mb-2">AI</div>
              <div class="text-cyan-100 text-sm">Assisted Development</div>
            </div>
          </div>

          <!-- Core Competencies Tags -->
          <div class="bg-slate-50 border border-slate-200 p-6 rounded-xl">
            <h3
              class="font-bold text-slate-800 mb-4 text-xs uppercase tracking-widest"
            >
              Core Competencies
            </h3>
            <div class="flex flex-wrap gap-2">
              {
                [
                  "Inventory Management",
                  "Stock Valuation",
                  "Cost Control",
                  "Purchasing",
                  "Purchase Orders",
                  "Quotations",
                  "Invoicing",
                  "Credit Notes",
                  "Exchange Rate Analysis",
                  "Softland ERP",
                  "VBA Automation",
                  "Report Automation",
                  "Data Analysis",
                  "Decision Support",
                  "Technical SEO",
                  "Web Development",
                  "AI-Assisted Dev",
                  "Process Optimization",
                ].map((item) => (
                  <span class="px-3 py-1 bg-white border border-slate-300 text-slate-700 text-xs rounded font-medium">
                    {item}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
