---
import { personalInfo } from "../data/portfolio";
---

<section
  id="about"
  class="flex items-center justify-center min-h-[80vh] py-20 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900"
>
  <div class="w-full max-w-5xl mx-auto px-6">
    <div class="bg-white dark:bg-gray-900 rounded-3xl shadow-xl p-10 md:p-16">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <h2 class="text-5xl font-extrabold mb-4 text-gray-900 dark:text-white">
          About <span class="text-blue-600">Me</span>
        </h2>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300">
          Perfil profesional orientado a operaciones, ERP y desarrollo web
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Textos a la izquierda -->
        <div class="space-y-8">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <p
              class="text-xl text-gray-700 dark:text-gray-300 leading-relaxed text-justify"
            >
              Trabajo en la gestión de inventario y en la definición de precios
              de productos, conectando información operativa y criterios
              comerciales para una toma de decisiones más clara.
            </p>
            <p
              class="text-xl text-gray-700 dark:text-gray-300 leading-relaxed text-justify"
            >
              También administro procesos internos con ERP (Softland),
              fortaleciendo control, trazabilidad y eficiencia. Como parte de
              esta visión integral, desarrollé el sitio web de la empresa con
              apoyo de herramientas de IA y conocimiento técnico personal.
            </p>
            <p
              class="text-xl text-gray-700 dark:text-gray-300 leading-relaxed text-justify"
            >
              Mi enfoque es profesional: transformar necesidades del negocio en
              procesos claros y soluciones digitales que aporten resultados.
            </p>
          </div>
        </div>
        <!-- Stats/Highlights a la derecha -->
        <div class="flex flex-col gap-8">
          <!-- Achievement Cards -->
          <div class="grid grid-cols-2 gap-6">
            <div
              class="bg-blue-50 dark:bg-blue-900/30 p-8 rounded-2xl text-center shadow-md"
            >
              <div
                class="text-4xl font-extrabold text-blue-600 dark:text-blue-400 mb-2"
              >
                1+
              </div>
              <div class="text-lg text-gray-700 dark:text-gray-300">
                Years of Experience
              </div>
            </div>
            <div
              class="bg-green-50 dark:bg-green-900/30 p-8 rounded-2xl text-center shadow-md"
            >
              <div
                class="text-4xl font-extrabold text-green-600 dark:text-green-400 mb-2"
              >
                1
              </div>
              <div class="text-lg text-gray-700 dark:text-gray-300">
                Completed Projects
              </div>
            </div>
          </div>
          <!-- What I Do debajo de los stats/highlights -->
          <div
            class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl shadow-md mt-4"
          >
            <h3 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">
              What I Do
            </h3>
            <div class="space-y-6">
              <div class="flex items-start space-x-4">
                <div
                  class="w-3 h-3 bg-blue-600 rounded-full mt-2 flex-shrink-0"
                >
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 dark:text-white">
                    Gestión de Inventario
                  </h4>
                  <p class="text-base text-gray-600 dark:text-gray-400">
                    Control de stock, costos y disponibilidad
                  </p>
                </div>
              </div>
              <div class="flex items-start space-x-4">
                <div
                  class="w-3 h-3 bg-green-600 rounded-full mt-2 flex-shrink-0"
                >
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 dark:text-white">
                    Pricing de Productos
                  </h4>
                  <p class="text-base text-gray-600 dark:text-gray-400">
                    Definición de precios con enfoque operativo y comercial
                  </p>
                </div>
              </div>
              <div class="flex items-start space-x-4">
                <div
                  class="w-3 h-3 bg-purple-600 rounded-full mt-2 flex-shrink-0"
                >
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 dark:text-white">
                    Procesos ERP + Web
                  </h4>
                  <p class="text-base text-gray-600 dark:text-gray-400">
                    Administración interna y desarrollo web asistido con IA
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
