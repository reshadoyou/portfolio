---
import { personalInfo } from '../data/portfolio';
---

<section id="about" class="py-20 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-white">
          About <span class="text-blue-600">Me</span>
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300">
          Learn more about my experience and passion for development
        </p>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Content -->
        <div class="space-y-6">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
              I'm a web developer passionate about creating innovative digital solutions 
              that solve real problems. With 1 year of experience in web development, 
              I've worked on diverse projects learning and applying different technologies.
            </p>
            
            <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
              My approach focuses on writing clean, maintainable, and efficient code, always 
              seeking best practices and the latest technologies. I specialize in the 
              JavaScript/TypeScript ecosystem, both frontend and backend.
            </p>
            
            <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
              When I'm not programming, I enjoy experimenting with new technologies, 
              especially AI, and constantly learning to expand my knowledge.
            </p>
          </div>
          
        
        <!-- Stats/Highlights -->
        <div class="space-y-8">
          <!-- Achievement Cards -->
          <div class="grid grid-cols-2 gap-6">
            <div class="bg-blue-50 dark:bg-blue-900/20 p-6 rounded-xl text-center">
              <div class="text-3xl font-bold text-blue-600 dark:text-blue-400 mb-2">1+</div>
              <div class="text-gray-700 dark:text-gray-300">Years of Experience</div>
            </div>
            
            <div class="bg-green-50 dark:bg-green-900/20 p-6 rounded-xl text-center">
              <div class="text-3xl font-bold text-green-600 dark:text-green-400 mb-2">2</div>
              <div class="text-gray-700 dark:text-gray-300">Completed Projects</div>
            </div>
          </div>
          
          <!-- What I Do -->
          <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-xl">
            <h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white">What I Do</h3>
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-blue-600 rounded-full mt-2 flex-shrink-0"></div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white">Frontend Development</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Modern and responsive interfaces</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-green-600 rounded-full mt-2 flex-shrink-0"></div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white">Backend Development</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Robust and scalable APIs</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-purple-600 rounded-full mt-2 flex-shrink-0"></div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white">AI Experimentation</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Exploring new technologies and AI tools</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
